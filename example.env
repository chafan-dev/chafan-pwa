# Local Vite env (recommended: copy to .env.local)
# Host only — no protocol. Must match allowlist in src/env.ts.
export VITE_APP_HOST=cha.fan
export VITE_APP_API=api_dev2.$VITE_APP_HOST
export VITE_APP_NAME=ChaFan
export VITE_APP_ENV=staging

# Optional
# export VITE_APP_SENTRY_DSN=
# export VITE_APP_LAMBDA=

# --- Cloudflare Pages / cloudflare.build.sh compatibility ---
# Deploy scripts still read VUE_APP_* and map them to VITE_APP_*.
export VUE_APP_HOST=cha.fan
export VUE_APP_API=api_dev2.$VUE_APP_HOST
export VUE_APP_NAME=ChaFan
export VUE_APP_ENV=staging
export VUE_APP_CDN_DOMAIN=cdn.jsdelivr.net
